# ============================================================================
# Jackpot Joker — environment variables
# ----------------------------------------------------------------------------
# The deployed web app (index.html, admin/index.html) is a static site and
# does NOT read any .env file — Firebase's client config in js/firebase-config.js
# is a public identifier, not a secret, so it's committed directly. See the
# "Security model" section in README.md for why that's safe.
#
# The variables below are only used by the OPTIONAL local helper script at
# scripts/create-admin.js, which provisions admin login accounts using the
# Firebase Admin SDK. Copy this file to .env inside /scripts (or the repo
# root) and fill in real values from a Firebase service-account key —
# never commit the real .env file.
# ============================================================================

# Option A: point at a downloaded service-account JSON file (simplest)
FIREBASE_ADMIN_CREDENTIALS_FILE=./service-account.json

# Option B: inline credentials instead of a file (used only if Option A is unset)
FIREBASE_ADMIN_PROJECT_ID=jackpot-joker-3d398
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@jackpot-joker-3d398.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
