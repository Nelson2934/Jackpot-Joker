rules_version = '2';

// ============================================================================
// JACKPOT JOKER — FIRESTORE SECURITY RULES
// ----------------------------------------------------------------------------
// Design notes (see README.md "Security model" for the full write-up):
//
// 1. settings/public   — jackpot amount, deck size, removed cards, status.
//                         Readable by everyone (it drives the public display),
//                         writable only by signed-in admins.
//
// 2. settings/private  — ONLY the jokerCardPosition. This must never be
//                         readable by the public, or anyone could open dev
//                         tools and see which card wins before the draw.
//                         Readable/writable only by signed-in admins.
//
// 3. entrants           — names + emails are personal data. Never exposed to
//                         the public page directly; only admins can read the
//                         full list. (The public page shows an aggregate
//                         count via settings/public.activeEntrantsCount.)
//
// 4. draws               — the detailed internal draw log. Admin-only, since
//                         it's a superset of what's shown publicly.
//
// 5. history             — the public-facing "previous winners" feed. Safe to
//                         expose (winner name, card, date, result) — readable
//                         by everyone, writable only by admins.
//
// 6. auditLogs           — internal record of admin actions. Admin-only.
//
// This app treats "signed in via Firebase Auth" as "is an admin" — admin
// accounts are provisioned manually in the Firebase console (see README).
// If you need multiple permission tiers later, layer custom claims on top.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null;
    }

    match /settings/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/private {
      allow read, write: if isAdmin();
    }

    match /entrants/{entrantId} {
      allow read, write: if isAdmin();
    }

    match /draws/{drawId} {
      allow read, write: if isAdmin();
    }

    match /history/{historyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
